# === LLMバックエンド選択 ===
# ollama: Ollama APIで実行（デフォルト）
# lmstudio: LM Studio の OpenAI互換APIで実行
LLM_BACKEND=ollama

# === ベンチマーク対象モデル（カンマ区切り）===
# Ollama の場合: Ollama で利用可能なモデル名を指定する
# LM Studio の場合: LM Studio にロード済みのモデル識別子を指定する
BENCHMARK_MODELS=model_name1,model_name2,model_name3

# === 実行するベンチマーク（カンマ区切り）===
# 選択肢: MMLU, TruthfulQA, GSM8K
BENCHMARK_TYPES=MMLU,TruthfulQA,GSM8K

# === MMLU設定 ===
# 全科目実行は時間がかかるため、科目を絞る（カンマ区切り、空欄で全科目）
# 選択肢: HIGH_SCHOOL_COMPUTER_SCIENCE,ASTRONOMY,HIGH_SCHOOL_MATHEMATICS
MMLU_TASKS=HIGH_SCHOOL_COMPUTER_SCIENCE,ASTRONOMY,HIGH_SCHOOL_MATHEMATICS
# 各科目5問（MAX5）
MMLU_N_SHOTS=5

# === TruthfulQA設定 ===
# MC1（1問1答）またはMC2（複数正解）
TRUTHFULQA_MODE=MC1
# カテゴリーを絞る（カンマ区切り、空欄で全38カテゴリー・817問）
# 全カテゴリー一覧:
#   ADVERTISING, CONFUSION_OTHER, CONFUSION_PEOPLE, CONFUSION_PLACES,
#   CONSPIRACIES, DISTRACTION, ECONOMICS, EDUCATION, FICTION, FINANCE,
#   HEALTH, HISTORY, INDEXICAL_ERROR_IDENTITY, INDEXICAL_ERROR_LOCATION,
#   INDEXICAL_ERROR_OTHER, INDEXICAL_ERROR_TIME, LANGUAGE, LAW,
#   LOGICAL_FALSEHOOD, MANDELA_EFFECT, MISCONCEPTIONS,
#   MISCONCEPTIONS_TOPICAL, MISINFORMATION, MISQUOTATIONS,
#   MYTHS_AND_FAIRYTALES, NUTRITION, PARANORMAL, POLITICS, PROVERBS,
#   PSYCHOLOGY, RELIGION, SCIENCE, SOCIOLOGY, STATISTICS, STEREOTYPES,
#   SUBJECTIVE, SUPERSTITIONS, WEATHER
TRUTHFULQA_TASKS=MISCONCEPTIONS,HEALTH,NUTRITION,SCIENCE,SUPERSTITIONS,CONSPIRACIES,MISQUOTATIONS,MYTHS_AND_FAIRYTALES,MANDELA_EFFECT,PROVERBS,FICTION,HISTORY,PSYCHOLOGY,LAW,PARANORMAL

# === GSM8K設定 ===
# 全1319問のうち何問実行するか（0で全問）
GSM8K_N_PROBLEMS=100
GSM8K_N_SHOTS=3
GSM8K_ENABLE_COT=true
# or false

# === Ollama設定（LLM_BACKEND=ollama の場合に使用）===
OLLAMA_BASE_URL=http://localhost:11434

# === LM Studio設定（LLM_BACKEND=lmstudio の場合に使用）===
# LM Studio のローカルサーバーURL（末尾に /v1 を含める）
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LM Studio は認証不要だが、OpenAI ライブラリがキーを要求するためダミー値を設定
LMSTUDIO_API_KEY=lm-studio

# === deepeval タイムアウト設定 ===
# ローカルLLMは応答が遅いため、デフォルトのタイムアウトでは不足する
# 1問あたりの最大待機時間（秒）。ローカル9Bモデルでは600〜900秒を推奨
DEEPEVAL_PER_TASK_TIMEOUT_SECONDS_OVERRIDE=800
# 1回のAPI呼び出しの最大待機時間（秒）
DEEPEVAL_PER_ATTEMPT_TIMEOUT_SECONDS_OVERRIDE=600
# リトライ回数（初回 + リトライ回数）。ローカルLLMではリトライを減らす
DEEPEVAL_RETRY_MAX_ATTEMPTS=2
# タイムアウトを完全に無効化する場合は以下を有効にする（非推奨）
# DEEPEVAL_DISABLE_TIMEOUTS=true